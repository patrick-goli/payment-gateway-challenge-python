{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI - Debug Payment Gateway",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "payment_gateway_api.app:app",
                "--reload",
